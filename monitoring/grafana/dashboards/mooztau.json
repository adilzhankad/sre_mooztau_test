{
  "uid": "mooztau-overview",
  "title": "MoozTau Platform Overview",
  "tags": ["mooztau"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "" },
        "query": "label_values(up, job)",
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Services Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "targets": [
        { "expr": "up{job=~\"$job\"}", "legendFormat": "{{ job }}" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_requests_total{job=~\"$job\"}[1m]))",
          "legendFormat": "{{ job }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15 } }
      }
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_requests_total{job=~\"$job\", status=~\"5..\"}[1m])) / sum by (job) (rate(http_requests_total{job=~\"$job\"}[1m])) * 100",
          "legendFormat": "{{ job }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "fillOpacity": 15 },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 5 }] }
        }
      }
    },
    {
      "id": 4,
      "title": "Latency P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, job) (rate(http_request_duration_seconds_bucket{job=~\"$job\"}[1m])))",
          "legendFormat": "{{ job }} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, job) (rate(http_request_duration_seconds_bucket{job=~\"$job\"}[1m])))",
          "legendFormat": "{{ job }} p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, job) (rate(http_request_duration_seconds_bucket{job=~\"$job\"}[1m])))",
          "legendFormat": "{{ job }} p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "id": 5,
      "title": "Requests by Status Code",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum by (status, job) (rate(http_requests_total{job=~\"$job\"}[1m]))",
          "legendFormat": "{{ job }} [{{ status }}]"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 15 } }
      }
    },
    {
      "id": 6,
      "title": "Requests by Endpoint (Top 10)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "topk(10, sum by (handler, job) (rate(http_requests_total{job=~\"$job\"}[5m])))",
          "legendFormat": "{{ job }} {{ handler }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    }
  ],
  "schemaVersion": 39
}
